{
  "name": "@yourtechtribe-labs/koncept-cli",
  "version": "0.2.0-alpha.3",
  "description": "CLI for koncepto — init, verify, list, link operations on .koncept/ concept graphs.",
  "keywords": [
    "mcp",
    "concept-graph",
    "knowledge-graph",
    "yaml",
    "cli",
    "developer-tools",
    "ai-tools"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "koncepto": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "echo 'lint stub'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@yourtechtribe-labs/koncept-core": "workspace:^0.2.0-alpha.0",
    "glob": "13.0.6",
    "yaml": "2.9.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "license": "MIT",
  "homepage": "https://github.com/yourtechtribe-labs/koncept-mcp#readme",
  "bugs": {
    "url": "https://github.com/yourtechtribe-labs/koncept-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourtechtribe-labs/koncept-mcp",
    "directory": "packages/koncept-cli"
  }
}
