{
  "name": "@yourtechtribe-labs/koncept-mcp-server",
  "version": "0.2.0-alpha.6",
  "mcpName": "io.github.yourtechtribe-labs/koncept-mcp-server",
  "description": "MCP server exposing semantic concept graph tools (koncept_search, koncept_get, koncept_for_file, koncept_invariants_at_scope).",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "claude",
    "claude-code",
    "ai-tools",
    "concept-graph",
    "knowledge-graph",
    "yaml"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "koncept-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "echo 'lint stub'",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@yourtechtribe-labs/koncept-core": "workspace:^",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "license": "MIT",
  "homepage": "https://github.com/yourtechtribe-labs/koncept-mcp#readme",
  "bugs": {
    "url": "https://github.com/yourtechtribe-labs/koncept-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourtechtribe-labs/koncept-mcp",
    "directory": "packages/koncept-mcp-server"
  }
}
